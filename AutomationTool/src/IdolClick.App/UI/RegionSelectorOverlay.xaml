<Window x:Class="IdolClick.UI.RegionSelectorOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Region" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">

    <Grid>
        <!-- Semi-transparent overlay -->
        <Rectangle x:Name="OverlayBackground" Fill="{StaticResource SelectionOverlayBrush}" IsHitTestVisible="False"/>

        <!-- Selection rectangle -->
        <Canvas x:Name="SelectionCanvas">
            <Rectangle x:Name="SelectionRect" 
                       Stroke="{StaticResource SelectionStrokeBrush}" 
                       StrokeThickness="2" 
                       StrokeDashArray="4 2"
                       Fill="{StaticResource SelectionFillBrush}"
                       Visibility="Collapsed"/>
            
            <!-- Dimension label -->
            <Border x:Name="DimensionLabel" 
                    Background="{StaticResource OverlayBackdropBrush}" 
                    CornerRadius="4" 
                    Padding="8,4"
                    Visibility="Collapsed">
                <TextBlock x:Name="DimensionText" 
                           Foreground="{StaticResource TextBrush}" 
                           FontFamily="{StaticResource MonoFont}" 
                           FontSize="{StaticResource FontSizeBodySm}"/>
            </Border>
        </Canvas>

        <!-- Instructions panel -->
        <Border HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="0,50,0,0"
                Background="{StaticResource OverlayBackdropBrush}" 
                CornerRadius="8" 
                Padding="20,15">
            <StackPanel>
                <TextBlock Text="🖱 Click and drag to select a region" 
                           Foreground="{StaticResource TextBrush}" 
                           FontSize="{StaticResource FontSizeTitle}" 
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Press ESC to cancel • Enter to confirm" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="{StaticResource FontSizeBodySm}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Coordinates display -->
        <Border x:Name="CoordinatesPanel"
            HorizontalAlignment="Left" 
            VerticalAlignment="Bottom" 
            Margin="20,0,0,20"
            Background="{StaticResource OverlayBackdropBrush}" 
            CornerRadius="4" 
            Padding="12,8">
            <TextBlock x:Name="CoordinatesText" 
                   Foreground="{StaticResource TextBrush}" 
                   FontFamily="{StaticResource MonoFont}" 
                   FontSize="{StaticResource FontSizeCaption}"
                       Text="Position: (0, 0)"/>
        </Border>
    </Grid>
</Window>
