<Window x:Class="IdolClick.UI.CapturePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Preview"
        Width="980" Height="720"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterOwner"
    Background="{StaticResource BackgroundBrush}"
    KeyDown="Window_KeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource GlassPanelBorder}" Padding="18,16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HeaderTitleText" Text="Capture Preview" Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource HeadingFont}" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="HeaderMetaText" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" Margin="0,5,0,0"/>
                    <TextBlock x:Name="HeaderSelectionText" Text="" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="11.5" Margin="0,5,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Open file" Style="{StaticResource SmallOutlineButton}" Click="OpenFile_Click"/>
                    <Button Content="Open folder" Style="{StaticResource SmallOutlineButton}" Click="OpenFolder_Click" Margin="6,0,0,0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassPanelBorder}" Padding="14" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="PreviousArtifactButton" Content="◀" Style="{StaticResource PremiumOutlineButton}" Width="42" Height="42"
                            VerticalAlignment="Center" Margin="0,0,12,0" Click="PreviousArtifact_Click"/>
                    <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="Fant"/>
                    <TextBlock x:Name="EmptyPreviewText" Text="No preview available" Visibility="Collapsed"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="NextArtifactButton" Content="▶" Style="{StaticResource PremiumOutlineButton}" Width="42" Height="42"
                            VerticalAlignment="Center" Margin="12,0,0,0" Click="NextArtifact_Click"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassPanelBorder}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Artifacts" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="Select an image from this grouped capture." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="ArtifactsListBox" Grid.Row="1" BorderThickness="0" Background="Transparent"
                             SelectionChanged="ArtifactsListBox_SelectionChanged" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CaptureTileBorder}" Padding="8" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border CornerRadius="8" ClipToBounds="True" Background="{StaticResource SurfaceBrush}" Height="58" Width="68">
                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TargetName}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Kind}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource CaptureTileBorder}" Padding="10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Voice notes" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                <WrapPanel Grid.Column="1">
                                    <Button Content="Play" Style="{StaticResource SmallOutlineButton}" Click="PlayNote_Click"/>
                                    <Button Content="Stop" Style="{StaticResource SmallOutlineButton}" Click="StopNote_Click" Margin="6,0,0,0"/>
                                </WrapPanel>
                            </Grid>
                            <TextBlock x:Name="NotesHelpText" Text="If this capture event has related voice notes, you can play them here." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <ListBox x:Name="NotesListBox" BorderThickness="0" Background="Transparent" Margin="0,8,0,0" SelectionChanged="NotesListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CaptureTileBorder}" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource GlassPanelBorder}" Padding="14,10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close" Style="{StaticResource SmallPrimaryButton}" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>