<UserControl x:Class="IdolClick.UI.Controls.CapturePanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IdolClick.UI.Controls"
             Background="{StaticResource SurfaceBrush}"
             Focusable="True"
             PreviewKeyDown="CapturePanelControl_PreviewKeyDown">
    <UserControl.Resources>
        <DataTemplate x:Key="CaptureProjectResourceItemTemplate">
            <Border Style="{StaticResource CaptureTileBorder}" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{Binding AccentBrush}" CornerRadius="10" Padding="8,3" VerticalAlignment="Top" Margin="10,0,0,0">
                        <TextBlock Text="{Binding CountLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="CaptureExplorerListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,5,8,5"/>
        </Style>

        <DataTemplate x:Key="CaptureProfileExplorerItemTemplate">
            <Border Style="{StaticResource CaptureFolderCard}" BorderBrush="{Binding AccentBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Width="46" Height="12" Background="{Binding AccentTintBrush}" CornerRadius="8,8,0,0" Margin="2,0,0,-1"/>
                    <Border Grid.Row="1" Width="74" Height="58" CornerRadius="14" Background="{Binding AccentTintBrush}" BorderBrush="{Binding AccentBrush}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                            <Rectangle Fill="{Binding AccentTintBrush}" Opacity="0.45"/>
                            <Ellipse Width="34" Height="34" Fill="{StaticResource SurfaceTintBrush}" Stroke="{Binding AccentBrush}" StrokeThickness="1.2"/>
                            <TextBlock Text="{Binding Glyph}" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0" Background="{Binding AccentBrush}" CornerRadius="10" Padding="6,2">
                                <TextBlock Text="{Binding FolderBadge}" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="10,2,0,0">
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="13.5"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="{Binding AccentBrush}" FontSize="10.5" Margin="0,4,0,0" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TargetCountLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding LastCaptureLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Grid.RowSpan="2" Text="Open  →" Foreground="{Binding AccentBrush}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CaptureWorkspaceHeaderPanel}" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Capture workspace" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Build reusable profiles for regions and windows, then trigger a grouped snap event from the workspace or global hotkey."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBodySm}"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Capture selected" Style="{StaticResource PremiumPrimaryButton}" Click="CaptureSelected_Click"/>
                    <Button Content="Save review" Style="{StaticResource PremiumOutlineButton}" Click="SaveReviewBuffer_Click" Margin="8,0,0,0"/>
                    <Button Content="Focus orb" Style="{StaticResource PremiumOutlineButton}" Click="FocusOrb_Click" Margin="8,0,0,0"/>
                    <Button Content="Refresh windows" Style="{StaticResource PremiumOutlineButton}" Click="RefreshWindows_Click" Margin="8,0,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Style="{StaticResource CaptureTileBorder}" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Prompt pack runner" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="Run a canonical monitoring pack from plain English. Examples: monitor google search for windows ui automation, monitor stock MSFT on yahoo finance, monitor a youtube video."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBodySm}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBox x:Name="CapturePromptPackBox" Margin="0,10,0,0" MinWidth="360"
                                     ToolTip="Describe the capture pack you want to run. Press Enter to run a smoke pass."
                                     KeyDown="CapturePromptPackBox_KeyDown"/>
                            <TextBlock x:Name="CapturePromptPackStatusText" Text="" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <ItemsControl x:Name="CapturePromptHistoryItemsControl" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Prompt}" Tag="{Binding}" Click="CapturePromptHistoryRun_Click"
                                                Style="{StaticResource PremiumOutlineButton}" Margin="0,0,8,8" ToolTip="Click to rerun this prompt with its last mode."/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Button x:Name="RunPromptPackButton" Content="Run smoke" Style="{StaticResource PremiumPrimaryButton}" Click="RunPromptPack_Click"/>
                            <Button x:Name="RunPromptPackFullButton" Content="Run full" Style="{StaticResource PremiumOutlineButton}" Click="RunPromptPackFull_Click" Margin="8,0,0,0"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0" Style="{StaticResource CaptureTileBorder}" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Review buffer" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ReviewStatusText" Text="Review buffer status will appear here." Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBodySm}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ReviewHealthText" Text="" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="Shortcuts: Enter open • Ctrl+Enter capture • Ctrl+N region • Ctrl+Shift+N window • F2 configure • Delete remove • Esc back"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Content="Open review folder" Style="{StaticResource PremiumOutlineButton}" Click="OpenReviewFolder_Click"/>
                            <Button Content="Settings" Style="{StaticResource PremiumOutlineButton}" Click="OpenSettings_Click" Margin="8,0,0,0"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CaptureWorkspaceShell}" Padding="12" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="PreviewDockSplitterColumn" Width="8"/>
                    <ColumnDefinition x:Name="PreviewDockColumn" Width="400"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Project Explorer (always visible) -->
                <Border Grid.Column="0" Style="{StaticResource CaptureWorkspaceHighlightCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource CaptureWorkspaceHeaderBrush}" Padding="12,10" CornerRadius="14,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Projects" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"/>
                                <TextBlock Text="Capture profiles act as project folders." Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <ListBox x:Name="ProfilesListBox" Grid.Row="1" BorderThickness="0"
                                 SelectionChanged="ProfilesListBox_SelectionChanged"
                                 MouseDoubleClick="ProfilesListBox_DoubleClick"
                                 Background="{StaticResource SurfaceBrush}">
                            <ListBox.ItemContainerStyle>
                                <StaticResource ResourceKey="CaptureExplorerListBoxItemStyle"/>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="CaptureProfileExplorerItemTemplate"/>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" Background="{StaticResource CaptureWorkspaceHeaderBrush}" Padding="12,10" CornerRadius="0,0,14,14">
                            <WrapPanel>
                                <Button Content="Open selected" Style="{StaticResource PremiumPrimaryButton}" Click="OpenProfile_Click"/>
                                <Button Content="Export" Style="{StaticResource PremiumOutlineButton}" Click="ExportProfile_Click" Margin="8,0,0,0"/>
                                <Button Content="Delete" Style="{StaticResource PremiumDangerButton}" Click="DeleteProfile_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

                <!-- CENTER: Canvas (persistent nav bar + switching content panes + action bar) -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Shared nav bar -->
                    <Border Grid.Row="0" Style="{StaticResource CaptureWorkspaceCard}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <WrapPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <Border Style="{StaticResource CaptureBreadcrumbPill}">
                                    <TextBlock Text="Capture" Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="›" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Style="{StaticResource CaptureBreadcrumbPill}">
                                    <TextBlock Text="Library" Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock x:Name="BreadcrumbProfileArrow" Text="›" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <Border x:Name="BreadcrumbProfileBorder" Style="{StaticResource CaptureBreadcrumbPill}" Visibility="Collapsed">
                                    <TextBlock x:Name="BreadcrumbProfileText" Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock x:Name="BreadcrumbLeafArrow" Text="›" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <Border x:Name="BreadcrumbLeafBorder" Style="{StaticResource CaptureBreadcrumbPill}" Visibility="Collapsed">
                                    <TextBlock x:Name="BreadcrumbLeafText" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </WrapPanel>

                            <Button x:Name="NavBackButton" Grid.Row="1" Grid.Column="0" Content="← Back" Style="{StaticResource PremiumOutlineButton}" Click="NavBack_Click" Visibility="Collapsed"/>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock x:Name="NavKindText" Text="Profile library" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                                <TextBlock x:Name="NavTitleText" Text="Capture workspace" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <TextBlock x:Name="NavMetaText" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock x:Name="CaptureStatusText" Text="Ready" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" HorizontalAlignment="Right"/>
                                <Button x:Name="PreviewDockToggleButton" Content="Collapse preview" Style="{StaticResource PremiumOutlineButton}" Click="TogglePreviewDock_Click" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Library canvas -->
                    <ScrollViewer x:Name="LibraryCanvasPane" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource CaptureWorkspaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Project home" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                                    <TextBlock x:Name="LibrarySelectedProjectTitleText" Text="Select a capture project" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="18" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="LibrarySummaryText" Text="Choose a profile to see its summary." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LibraryProjectManifestText" Text="Projects collect assets, captures, and reusable output in one docked workspace." Foreground="{StaticResource WorkspaceCaptureBrush}" Margin="0,8,0,0" FontSize="10.5" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LibraryProjectOutputText" Text="Output path will appear here." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" FontSize="10.5" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Project resources" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Treat each capture profile like a project with assets, history, and a dedicated output root." Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <ItemsControl x:Name="LibraryProjectResourcesItemsControl" Margin="0,12,0,0" ItemTemplate="{StaticResource CaptureProjectResourceItemTemplate}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Recent reviews" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Save now" Style="{StaticResource PremiumOutlineButton}" Click="SaveReviewBuffer_Click"/>
                                    </Grid>
                                    <ListBox x:Name="RecentReviewBundlesListBox" BorderThickness="0" Background="Transparent" Margin="0,8,0,0" SelectionChanged="RecentReviewBundlesListBox_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CaptureTileBorder}" Padding="8" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource CaptureWorkspaceHeaderBrush}" BorderBrush="{StaticResource CaptureWorkspaceInsetBrush}" BorderThickness="1">
                                                            <TextBlock Text="▶" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding PrimaryLabel}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SecondaryLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,3,0,0"/>
                                                            <TextBlock Text="{Binding DetailLabel}" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" Margin="0,3,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Profile canvas -->
                    <ScrollViewer x:Name="ProfileCanvasPane" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>
                            <Border Style="{StaticResource CaptureWorkspaceCard}">
                                <StackPanel>
                                    <TextBlock x:Name="SelectedProfileTitle" Text="Choose or create a profile"
                                               Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ProfileViewSummaryText" Text="Open a profile to see its capture targets and recent output."
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ProjectManifestText" Text="No project selected." Foreground="{StaticResource WorkspaceCaptureBrush}" Margin="0,8,0,0" FontSize="10.5" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ProjectOutputPathText" Text="No output directory yet." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" FontSize="10.5" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Project resources" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Think of this like a video-editing project: reusable assets, indexed outputs, and a preview dock beside the canvas." Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <ItemsControl x:Name="ProjectResourcesItemsControl" Margin="0,12,0,0" ItemTemplate="{StaticResource CaptureProjectResourceItemTemplate}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Targets" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Remove selected" Style="{StaticResource PremiumOutlineButton}" Click="RemoveTarget_Click"/>
                                    </Grid>
                                    <TextBlock Text="Subfolders inside this profile" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,8"/>
                                    <ListBox x:Name="TargetsListBox" BorderThickness="0" Background="Transparent" Margin="0,8,0,0" SelectionMode="Single" MouseDoubleClick="TargetsListBox_DoubleClick">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CaptureSubfolderCard}" Width="196" Margin="0,0,8,8" BorderBrush="{Binding AccentBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Width="38" Height="10" Background="{Binding AccentTintBrush}" CornerRadius="8,8,0,0" Margin="2,0,0,-1"/>
                                                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CaptureWorkspaceInsetBrush}" BorderThickness="1" CornerRadius="12" Padding="10,10,10,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="54"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="44" Height="44" Background="{Binding AccentTintBrush}" CornerRadius="12" ClipToBounds="True">
                                                                    <Grid>
                                                                        <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                                        <Rectangle Fill="{Binding AccentTintBrush}" Opacity="0.35"/>
                                                                        <TextBlock Text="{Binding Glyph}" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding KindLabel}" Foreground="{Binding AccentBrush}" FontSize="10.5" Margin="0,3,0,0" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding PathHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding LastCaptureLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Target canvas -->
                    <Grid x:Name="TargetCanvasPane" Grid.Row="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CaptureWorkspaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Target overview" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TargetDetailSummaryText" Text="Open a subfolder from the profile view to inspect its latest captures." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Latest preview" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="TargetPreviewMetaText" Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ListBox x:Name="TargetComparisonStripListBox" Grid.Row="1" Margin="0,0,0,10" BorderThickness="0" Background="Transparent" SelectionChanged="TargetComparisonStripListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,8,0"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CaptureTileBorder}" Width="112" Padding="6">
                                                    <StackPanel>
                                                        <Border Height="66" CornerRadius="10" ClipToBounds="True" Background="{StaticResource SurfaceBrush}">
                                                            <Grid>
                                                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                                <Rectangle Fill="{StaticResource SurfaceTintBrush}" Opacity="0.16"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                                        <TextBlock Text="{Binding DeltaLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Grid.Row="2" MinHeight="260" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CaptureWorkspaceInsetBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="TargetPreviewImage" Stretch="UniformToFill"/>
                                            <TextBlock x:Name="TargetPreviewEmptyText" Text="No target preview available yet." Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource CaptureWorkspaceCard}">
                            <StackPanel>
                                <TextBlock Text="Recent target captures" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="Each tile is a direct artifact tied to this target subfolder." Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <ListBox x:Name="TargetRecentArtifactsListBox" BorderThickness="0" Background="Transparent" Margin="0,12,0,0" SelectionChanged="TargetRecentArtifactsListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CaptureTileBorder}" Padding="8" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="76"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border CornerRadius="8" ClipToBounds="True" Background="{StaticResource SurfaceBrush}" Width="70" Height="54">
                                                        <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Artifact.TargetName}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource WorkspaceCaptureBrush}" FontSize="10.5" Margin="0,3,0,0" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding EventSummary}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Configure canvas -->
                    <ScrollViewer x:Name="ConfigureCanvasPane" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>
                            <Border Style="{StaticResource CaptureWorkspaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Profile details" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Name" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="ProfileNameTextBox" Grid.Column="1"/>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="File prefix" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="FilePrefixTextBox" Grid.Column="1"/>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Output folder" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="OutputDirectoryTextBox" Grid.Column="1"/>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Next note" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                                        <TextBox x:Name="NoteTextBox" Grid.Column="1" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CaptureWorkspaceCard}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Add new target" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Keep level 3 focused: choose what to add, then return to the profile view."
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>

                                    <ComboBox x:Name="WindowsComboBox" DisplayMemberPath="DisplayName" MinWidth="220" Margin="0,12,0,0"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Add screen region" Style="{StaticResource PremiumPrimaryButton}" Click="AddScreenRegionTarget_Click"/>
                                        <Button Content="Add window target" Style="{StaticResource PremiumOutlineButton}" Click="AddWindowTarget_Click" Margin="8,0,0,0"/>
                                        <Button Content="Add window region" Style="{StaticResource PremiumOutlineButton}" Click="AddWindowRegionTarget_Click" Margin="8,0,0,0"/>
                                        <Button Content="Refresh windows" Style="{StaticResource PremiumOutlineButton}" Click="RefreshWindows_Click" Margin="8,0,0,0"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Row 2: Shared action bar -->
                    <Border Grid.Row="2" Background="{StaticResource CaptureWorkspaceHeaderBrush}" Padding="14,12" CornerRadius="14" Margin="0,12,0,0">
                        <Grid>
                            <WrapPanel x:Name="LibraryActionBar">
                                <Button Content="New screen region" Style="{StaticResource PremiumPrimaryButton}" Click="NewScreenRegionProfile_Click"/>
                                <Button Content="New window" Style="{StaticResource PremiumOutlineButton}" Click="NewWindowProfile_Click" Margin="8,0,0,0"/>
                                <Button Content="Import profile" Style="{StaticResource PremiumOutlineButton}" Click="ImportProfile_Click" Margin="8,0,0,0"/>
                                <Button Content="Clean orphaned" Style="{StaticResource PremiumOutlineButton}" Click="CleanOrphanedCaptures_Click" Margin="8,0,0,0"/>
                                <Button Content="Refresh windows" Style="{StaticResource PremiumOutlineButton}" Click="RefreshWindows_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel x:Name="ProfileActionBar" Visibility="Collapsed">
                                <Button Content="Capture now" Style="{StaticResource PremiumPrimaryButton}" Click="CaptureSelected_Click"/>
                                <Button Content="Configure project" Style="{StaticResource PremiumOutlineButton}" Click="OpenConfigureView_Click" Margin="8,0,0,0"/>
                                <Button Content="Focus orb" Style="{StaticResource PremiumOutlineButton}" Click="FocusOrb_Click" Margin="8,0,0,0"/>
                                <Button Content="Delete profile" Style="{StaticResource PremiumDangerButton}" Click="DeleteProfile_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel x:Name="TargetActionBar" Visibility="Collapsed">
                                <Button Content="Open file" Style="{StaticResource PremiumPrimaryButton}" Click="OpenTargetArtifactFile_Click"/>
                                <Button Content="Open folder" Style="{StaticResource PremiumOutlineButton}" Click="OpenTargetArtifactFolder_Click" Margin="8,0,0,0"/>
                                <Button Content="Configure profile" Style="{StaticResource PremiumOutlineButton}" Click="ConfigureTargetFromDetail_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel x:Name="ConfigureActionBar" Visibility="Collapsed">
                                <Button Content="Save profile" Style="{StaticResource PremiumPrimaryButton}" Click="SaveProfile_Click"/>
                                <Button Content="Export profile" Style="{StaticResource PremiumOutlineButton}" Click="ExportProfile_Click" Margin="8,0,0,0"/>
                                <Button Content="Back to profile" Style="{StaticResource PremiumOutlineButton}" Click="BackToProfile_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

                <!-- RIGHT: Preview dock (always visible, collapsible) -->
                <Border x:Name="PreviewDockBorder" Grid.Column="4" Style="{StaticResource CaptureWorkspaceCard}" SizeChanged="PreviewDockBorder_SizeChanged">
                    <StackPanel>
                        <TextBlock Text="Preview dock" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                        <TextBlock x:Name="PreviewDockTitleText" Text="No project selected" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeTitle}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="PreviewDockMetaText" Text="Select a capture project to inspect its preview dock." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        <Border Margin="0,12,0,0" Style="{StaticResource CaptureTileBorder}" Padding="0" MinHeight="220" ClipToBounds="True">
                            <Grid>
                                <Image x:Name="PreviewDockImage" Stretch="UniformToFill"/>
                                <TextBlock x:Name="PreviewDockEmptyText" Text="No preview available yet." Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,12,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Recent captures" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="Pop out" Style="{StaticResource PremiumOutlineButton}" Click="PreviewSelectedCapture_Click"/>
                        </Grid>
                        <ListBox x:Name="PreviewDockCapturesListBox" BorderThickness="0" Background="Transparent" SelectionChanged="PreviewDockCapturesListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CaptureTileBorder}" Padding="8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="8" ClipToBounds="True" Background="{StaticResource SurfaceBrush}" Width="70" Height="54">
                                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProfileName}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>