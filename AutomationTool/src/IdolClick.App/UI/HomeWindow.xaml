<Window x:Class="IdolClick.UI.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdolClick"
        Width="1000" Height="700"
        MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeChanged="Window_SizeChanged">

    <Border Style="{StaticResource LauncherShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
                <Border Grid.Row="0" Background="{StaticResource LauncherHeaderBrush}"
                    CornerRadius="12,12,0,0" Padding="16,10"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="IdolClick" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="  •  Choose your mode" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Click="Close_Click"
                            Style="{StaticResource SmallIconButton}" FontSize="12" Padding="6,2"/>
                </Grid>
            </Border>

            <!-- Header -->
                <Border Grid.Row="1" Margin="24,20,24,0" Padding="20,18"
                    Style="{StaticResource LauncherHeaderPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="A family of desktop utilities" Foreground="{StaticResource TextBrush}"
                                   FontSize="25" FontWeight="SemiBold"/>
                        <TextBlock Text="Choose the workspace you need right now. IdolClick keeps automation, guided authoring, and utility-led workflows under one launcher without forcing a single mental model."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5"
                                   Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="20"/>
                        <WrapPanel Margin="0,14,0,0" ItemHeight="28">
                            <Border Margin="0,0,8,8" Style="{StaticResource LauncherPill}">
                                <TextBlock Text="Fast launch" Foreground="{StaticResource TextBrush}" FontSize="11.5"/>
                            </Border>
                            <Border Margin="0,0,8,8" Style="{StaticResource LauncherPill}">
                                <TextBlock Text="Utility-first navigation" Foreground="{StaticResource TextBrush}" FontSize="11.5"/>
                            </Border>
                            <Border Margin="0,0,8,8" Style="{StaticResource LauncherPill}">
                                <TextBlock Text="Shared desktop engine" Foreground="{StaticResource TextBrush}" FontSize="11.5"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Padding="18,16" CornerRadius="14"
                            Background="{StaticResource LauncherCardBrush}" BorderBrush="{StaticResource LauncherCardEdgeBrush}" BorderThickness="1.2"
                            MinWidth="228" VerticalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18" Color="{StaticResource LauncherShadowColor}"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Quick return" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5"/>
                            <TextBlock x:Name="LastUsedText" Text="Last used: Instinct"
                                       Foreground="{StaticResource TextBrush}" FontSize="16.5" FontWeight="SemiBold"
                                       Margin="0,6,0,4"/>
                            <TextBlock Text="Open the last workspace immediately, or choose another utility below."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5"
                                       TextWrapping="Wrap" LineHeight="18"/>
                            <Button x:Name="ContinueButton" Content="Continue with Instinct  →"
                                    Margin="0,16,0,0" Click="Continue_Click"
                                    Style="{StaticResource PremiumPrimaryButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Feature cards -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Margin="0" Padding="0">
            <StackPanel Margin="24,16,24,0">
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Automation workspaces" Foreground="{StaticResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Each workspace loads a different slice of the product, but they all share the same desktop runtime and configuration backbone."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" Margin="0,6,0,0"/>
                </StackPanel>

                <UniformGrid x:Name="CardsGrid" Columns="3" Margin="-8,0,-8,0">

                <!-- ═══ Classic (Instinct) ═══ -->
                <Border x:Name="CardClassic" Margin="8" Cursor="Hand"
                    Style="{StaticResource LauncherFeatureCard}"
                        MouseLeftButtonDown="Card_Click" Tag="Classic">
                    <Grid>
                        <!-- Accent bar at top -->
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0"
                                Background="{StaticResource AccentBrush}"/>
                        <StackPanel Margin="14,14">
                            <Border x:Name="LastUsedClassicBadge" Visibility="Collapsed"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" Padding="8,3"
                                    CornerRadius="10" Background="#220078D4">
                                <TextBlock Text="Last used" Foreground="{StaticResource AccentBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="Instinct" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="Classic Rule Engine" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"
                                       FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="17">
                                Auto-click buttons, monitor windows, and execute rules with zero AI. Pure deterministic automation.
                            </TextBlock>
                            <TextBlock Text="No API key needed" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                                <Button Content="Launch  →" Margin="0,8,0,0" Click="Launch_Click" Tag="Classic"
                                    Style="{StaticResource PremiumPrimaryButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Agent (Reason) ═══ -->
                <Border x:Name="CardAgent" Margin="8" Cursor="Hand"
                    Style="{StaticResource LauncherFeatureCard}"
                        MouseLeftButtonDown="Card_Click" Tag="Agent">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0"
                                Background="{StaticResource PrimaryBrush}"/>
                        <StackPanel Margin="14,14">
                            <Border x:Name="LastUsedAgentBadge" Visibility="Collapsed"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" Padding="8,3"
                                    CornerRadius="10" Background="#220078D4">
                                <TextBlock Text="Last used" Foreground="{StaticResource PrimaryBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="🧠" FontSize="28" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="Reason" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="AI Agent Mode" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"
                                       FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="17">
                                Chat with an AI that sees your desktop and acts on your behalf. Natural language automation.
                            </TextBlock>
                            <TextBlock Text="Requires LLM API key" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                                <Button Content="Launch  →" Margin="0,8,0,0" Click="Launch_Click" Tag="Agent"
                                    Style="{StaticResource PremiumPrimaryButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Teach ═══ -->
                <Border x:Name="CardTeach" Margin="8" Cursor="Hand"
                    Style="{StaticResource LauncherFeatureCard}"
                        MouseLeftButtonDown="Card_Click" Tag="Teach">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0"
                                Background="{StaticResource WarningBrush}"/>
                        <StackPanel Margin="14,14">
                            <Border x:Name="LastUsedTeachBadge" Visibility="Collapsed"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" Padding="8,3"
                                    CornerRadius="10" Background="#22F59E0B">
                                <TextBlock Text="Last used" Foreground="{StaticResource WarningBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="🎯" FontSize="28" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="Teach" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="Smart Sentence Builder" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"
                                       FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="17">
                                Build reusable automation flows step by step. Record, refine, and replay with precision.
                            </TextBlock>
                            <TextBlock Text="Requires LLM API key" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                                <Button Content="Launch  →" Margin="0,8,0,0" Click="Launch_Click" Tag="Teach"
                                    Style="{StaticResource PremiumPrimaryButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Capture ═══ -->
                <Border x:Name="CardCapture" Margin="8" Cursor="Hand"
                    Style="{StaticResource LauncherFeatureCard}"
                        MouseLeftButtonDown="Card_Click" Tag="Capture">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0"
                                Background="{StaticResource SuccessBrush}"/>
                        <StackPanel Margin="14,14">
                            <Border x:Name="LastUsedCaptureBadge" Visibility="Collapsed"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" Padding="8,3"
                                    CornerRadius="10" Background="#2210B981">
                                <TextBlock Text="Last used" Foreground="{StaticResource SuccessBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="📸" FontSize="28" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="Capture" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                                       Margin="0,8,0,2"/>
                            <TextBlock Text="Reusable Snap Profiles" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"
                                       FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="17">
                                Save reusable profiles for windows and regions, then trigger grouped snapshots instantly from the workspace or hotkey.
                            </TextBlock>
                            <TextBlock Text="No AI required" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                                <Button Content="Launch  →" Margin="0,8,0,0" Click="Launch_Click" Tag="Capture"
                                    Style="{StaticResource PremiumPrimaryButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                </UniformGrid>

                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="14"
                        Background="{StaticResource LauncherCardBrush}"
                        BorderBrush="{StaticResource LauncherCardEdgeBrush}" BorderThickness="1.1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.16" Color="{StaticResource LauncherShadowColor}"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Focused capture" Foreground="{StaticResource TextBrush}" FontSize="13.5" FontWeight="SemiBold"/>
                            <TextBlock Text="Reusable region and window snapshots are being added as a utility-led workflow, separate from the automation workspaces."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,14,0">
                            <TextBlock Text="Connectors" Foreground="{StaticResource TextBrush}" FontSize="13.5" FontWeight="SemiBold"/>
                            <TextBlock Text="API, MCP, and plug-in surfaces continue to sit beside the main workspaces so the launcher can evolve into a broader utility family."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Family model" Foreground="{StaticResource TextBrush}" FontSize="13.5" FontWeight="SemiBold"/>
                            <TextBlock Text="The welcome screen is now the product launcher: one place to enter the right utility without forcing every workflow into one panel."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="28,8,28,12">
                <TextBlock Text="Welcome launcher stays available on startup so the app can behave like a family of utilities, not a single locked mode."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock x:Name="VersionText" HorizontalAlignment="Right"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Resize grip (bottom-right) -->
            <Path Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="0,0,6,4" Data="M 0,12 L 12,0 M 4,12 L 12,4 M 8,12 L 12,8"
                  Stroke="{StaticResource BorderBrush}" StrokeThickness="1" Opacity="0.5"/>
        </Grid>
    </Border>
</Window>
