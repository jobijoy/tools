<Window x:Class="IdolClick.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Idol Click" 
        Height="480" Width="480"
        MinHeight="400" MinWidth="380"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Icon="/Assets/idol-click.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="{StaticResource FontSizeH2}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

            <Label Content="Toggle Hotkey" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="HotkeyBox" Margin="0,0,0,15" ToolTip="Keyboard shortcut to toggle automation (e.g., Ctrl+Alt+T)"/>

            <Label Content="Log Level" Foreground="{StaticResource TextSecondaryBrush}"/>
            <ComboBox x:Name="LogLevelCombo" Margin="0,0,0,15">
                <ComboBoxItem Content="Debug"/>
                <ComboBoxItem Content="Info"/>
                <ComboBoxItem Content="Warning"/>
                <ComboBoxItem Content="Error"/>
            </ComboBox>

            <TextBlock Text="Behavior" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,10"/>
            
            <CheckBox x:Name="ShowPanelOnStartCheck" Content="Show control panel on startup" Margin="0,0,0,10"/>
            <CheckBox x:Name="StartWithWindowsCheck" Content="Start Idol Click with Windows" Margin="0,0,0,10" ToolTip="Add to Windows startup"/>
            <CheckBox x:Name="MouseNudgeCheck" Content="Prevent sleep by nudging mouse" Margin="0,0,0,10"/>
            
            <TextBlock Text="Display" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,10"/>
            
            <CheckBox x:Name="ShowExecutionCountCheck" Content="Show session execution count column" Margin="0,0,0,10" ToolTip="Display 🔁 count for each rule (resets on restart)"/>
            <CheckBox x:Name="ClickRadarCheck" Content="Click Radar — show pulse animation at click point" Margin="0,0,0,10" ToolTip="Displays expanding concentric circles at each automated click so you can observe actions. Fully click-through, never steals focus."/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Safety" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,6"/>
            <TextBlock Text="Safety guardrails protect against accidental damage and runaway automation." 
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <Label Content="Kill Switch Hotkey" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <TextBox x:Name="KillSwitchHotkeyBox" Margin="0,0,0,10" 
                     ToolTip="Emergency stop hotkey — instantly disables all automation (e.g., Ctrl+Alt+Escape)"/>

            <Label Content="Allowed Processes (comma-separated)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <TextBox x:Name="AllowedProcessesBox" Margin="0,0,0,4" 
                     ToolTip="Only automate these processes. Supports wildcards (e.g., notepad, MyApp*). Leave empty to allow all."/>
            <TextBlock x:Name="AllowlistWarning" Text="⚠ No process allowlist set — automation can target any window" 
                       Foreground="{StaticResource WarningBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,10" Visibility="Collapsed"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="AI / Foundry" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,10"/>
            <TextBlock Text="These top-level app settings are the canonical home for your model endpoint, key, and Whisper configuration. Runtime agent settings mirror them automatically for backward compatibility."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            
            <Label Content="LLM Endpoint" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <TextBox x:Name="AgentEndpointBox" Margin="0,0,0,10" 
                     ToolTip="API endpoint URL (e.g., https://models.inference.ai.azure.com, http://localhost:11434/v1)"/>
            
            <Label Content="Model ID" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <TextBox x:Name="AgentModelBox" Margin="0,0,0,10" 
                     ToolTip="Model deployment name or ID (e.g., gpt-4o, gpt-4o-mini)"/>
            
            <Label Content="API Key" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <PasswordBox x:Name="AgentApiKeyBox" Margin="0,0,0,10" 
                         Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                         Padding="8,6"
                         ToolTip="API key for the LLM endpoint"/>
            
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Max Tokens" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="AgentMaxTokensBox" ToolTip="Maximum tokens per response (default: 4096)"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Temperature" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="AgentTemperatureBox" ToolTip="0.0 = deterministic, 1.0 = creative (default: 0.3)"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Vision Fallback" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,6"/>
            <TextBlock Text="Uses LLM vision to locate elements when UIA selectors fail. Requires a vision-capable model (gpt-4o, claude-3.5-sonnet, etc.)." 
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            
            <CheckBox x:Name="VisionFallbackCheck" Content="Enable vision fallback" Margin="0,0,0,10" 
                      ToolTip="When UIA selectors fail, capture a screenshot and ask the LLM to locate the element visually"/>
            
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Vision Model (optional)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="VisionModelBox" ToolTip="Separate model ID for vision requests. Leave empty to use the main model."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Confidence Threshold" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="VisionConfidenceBox" ToolTip="Minimum confidence (0.0–1.0) to accept vision results (default: 0.7)"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="🎤 Voice Input" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,6"/>
            <TextBlock Text="Push-to-talk voice input using Azure OpenAI Whisper. Uses the same endpoint and API key configured above. A Whisper model deployment is required on your Azure resource." 
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            
            <CheckBox x:Name="VoiceEnabledCheck" Content="Enable voice input (shows 🎤 mic button in Reason &amp; Teach modes)" Margin="0,0,0,10" 
                      ToolTip="When enabled, a microphone button appears in the chat and teach panels for push-to-talk voice commands"/>
            
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Whisper Endpoint (optional)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="WhisperEndpointBox" ToolTip="Dedicated endpoint for Whisper API. Leave empty to use the main Agent endpoint above."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Whisper API Key (optional)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <PasswordBox x:Name="WhisperApiKeyBox" ToolTip="Dedicated API key for the Whisper endpoint. Leave empty to use the main Agent API key."/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Whisper Deployment ID" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="WhisperDeploymentBox" ToolTip="Azure OpenAI deployment name for your Whisper model (default: whisper)"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Language (optional)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="VoiceLanguageBox" ToolTip="Language code or name (e.g., en, english, es, ja). Leave empty for auto-detect. Common names auto-convert to ISO-639-1."/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="VoiceConfigStatus" Text="" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Capture Orb" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,10"/>

            <TextBlock Text="The floating capture orb stays on top. Choose a preset corner or drag it using its handle and let the app remember the custom location."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Orb Placement" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <ComboBox x:Name="OrbPlacementCombo">
                        <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                        <ComboBoxItem Content="Bottom Left" Tag="BottomLeft"/>
                        <ComboBoxItem Content="Top Right" Tag="TopRight"/>
                        <ComboBoxItem Content="Top Left" Tag="TopLeft"/>
                        <ComboBoxItem Content="Custom (saved drag position)" Tag="Custom"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Bottom">
                    <CheckBox x:Name="RememberOrbLocationCheck" Content="Remember dragged custom position" Margin="0,24,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="OrbConfigStatus" Text="" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Review Buffer" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,10"/>

            <CheckBox x:Name="ReviewEnabledCheck" Content="Enable rolling review buffer" Margin="0,0,0,10"
                      ToolTip="Continuously saves lightweight review frames in the background so the last few minutes can be exported with a hotkey."/>
            <CheckBox x:Name="ReviewMicCheck" Content="Include microphone commentary" Margin="0,0,0,10"
                      ToolTip="Records microphone chunks alongside the rolling review buffer."/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Save Buffer Hotkey" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="ReviewHotkeyBox" ToolTip="Saves the last few minutes of the rolling review buffer."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Buffer Duration (minutes)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="ReviewDurationBox" ToolTip="How many minutes to keep in the rolling review buffer."/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <Label Content="Frame Interval (ms)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="ReviewFrameIntervalBox" ToolTip="Lower values capture more often but cost more CPU and disk."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <Label Content="Audio Chunk Seconds" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
                    <TextBox x:Name="ReviewAudioChunkBox" ToolTip="Length of microphone chunks stored in the rolling buffer."/>
                </StackPanel>
            </Grid>

            <Label Content="Review Output Folder (optional)" Foreground="{StaticResource TextSecondaryBrush}" Padding="0,0,0,2"/>
            <TextBox x:Name="ReviewOutputDirectoryBox" Margin="0,0,0,8"
                     ToolTip="Leave empty to save review bundles under the app reports folder."/>

            <TextBlock x:Name="ReviewConfigStatus" Text="" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <Separator Margin="0,15"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="📂 Config Folder" Style="{StaticResource ModernButton}" Click="OpenConfigFolder_Click" Margin="0,0,10,0"/>
                <Button Content="📋 Logs Folder" Style="{StaticResource ModernButton}" Click="OpenLogsFolder_Click"/>
                <Button Content="🎞 Review Folder" Style="{StaticResource ModernButton}" Click="OpenReviewFolder_Click" Margin="10,0,0,0"/>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Cancel" Style="{StaticResource ModernButton}" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
