{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jobijoy/IdolClick/main/schemas/capture-profile-pack.schema.json",
  "title": "IdolClick Capture Profile Pack v1",
  "description": "Reusable capture profile bundle with optional bootstrap flow and downstream queue/analyzer hints.",
  "type": "object",
  "required": ["schemaVersion", "packId", "name", "captureProfile"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "packId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "bootstrapFlowPath": {
      "type": "string",
      "description": "Optional relative path to a flow that opens/navigates the app before observation starts."
    },
    "inputs": {
      "type": "array",
      "description": "Optional runtime inputs that can be substituted into the pack using {{name}} tokens.",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "defaultValue": { "type": "string" },
          "example": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "statusSelectors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional selectors or logical labels that represent status checkpoints to watch."
    },
    "statusProbes": {
      "type": "array",
      "description": "Structured status probes used to validate bootstrap success and capture lightweight state context.",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["WindowTitle", "SelectorExists", "SelectorValue"]
          },
          "selector": { "type": "string" },
          "contains": { "type": "string" },
          "equals": { "type": "string" },
          "required": { "type": "boolean" },
          "useForChangeDetection": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "observationPlan": {
      "type": "object",
      "description": "Recommended runtime behavior for repeated observation and queueing.",
      "properties": {
        "triggerMode": {
          "type": "string",
          "enum": ["manual", "interval", "status-change", "hybrid"]
        },
        "intervalSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "audioClipSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "queueSnapshots": {
          "type": "boolean"
        },
        "statusChangeHint": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "queue": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "queueId": { "type": "string" },
        "consumerHint": { "type": "string" },
        "analysisHint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "captureProfile": {
      "$ref": "#/$defs/captureProfile"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "screenRegion": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "additionalProperties": false
    },
    "captureTarget": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["ScreenRegion", "Window", "WindowRegion"]
        },
        "processName": { "type": "string" },
        "windowTitle": { "type": "string" },
        "windowHandleHint": { "type": "integer" },
        "region": { "$ref": "#/$defs/screenRegion" }
      },
      "additionalProperties": false
    },
    "captureProfile": {
      "type": "object",
      "required": ["id", "name", "targets"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "filePrefix": { "type": "string" },
        "outputDirectory": { "type": "string" },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/captureTarget" }
        }
      },
      "additionalProperties": false
    }
  }
}
